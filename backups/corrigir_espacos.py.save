from pathlib import Path
import re
import wordninja

entrada = Path("Jackson_Steven_J_Rethinking_Repair_Media.md")
saida = Path("Jackson_Steven_J_Rethinking_Repair_Media-espacos.md")

texto = entrada.read_text(encoding="utf-8", errors="replace")

# normaliza pontuação estranha
texto = texto.replace("，", ",").replace("（", "(").replace("）", ")")

# espaço depois de pontuação
texto = re.sub(r"([.,;:!?])([A-Z])", r"\1 \2", texto)
texto = re.sub(r"([a-z])([A-Z])", r"\1 \2", texto)

# separa sequências muito longas sem espaço
def separar(match):
    palavra = match.group(0)
    if len(palavra) < 14:
        return palavra
    return " ".join(wordninja.split(palavra))

texto = re.sub(r"\b[a-zA-Z]{14,}\b", separar, texto)

# normaliza espaços
texto = re.sub(r"[ \t]{2,}", " ", texto)
texto = re.sub(r"\n{3,}", "\n\n", texto)

saida.write_text(texto, encoding="utf-8")

print(f"Arquivo corrigido salvo em: {saida}")
