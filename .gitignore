# ═══════════════════════════════════════════════════════════════
# ESTRATÉGIA: Rejeitar tudo, permitir apenas arquivos específicos
# ═══════════════════════════════════════════════════════════════

# REJEITAR TUDO por padrão
/*
!/.gitignore
!/.github/

# Permitir APENAS os arquivos do projeto público
!/digerir.py
!/rato/
!/rato/scripts/
!/rato/scripts/digerir.py
!/rato/scripts/escavar.py
!/rato/scripts/farejar.py
!/rato/scripts/limpar.py
!/rato/scripts/roer.py
!/rato/scripts/rato.sh
!/rato/scripts/rato_toca.py
!/rato/scripts/README.md

# Rejeitar explicitamente dados pessoais
/rato/*
!/rato/scripts/
/rato/scripts/*
!/rato/scripts/digerir.py
!/rato/scripts/escavar.py
!/rato/scripts/farejar.py
!/rato/scripts/limpar.py
!/rato/scripts/roer.py
!/rato/scripts/rato.sh
!/rato/scripts/rato_toca.py
!/rato/scripts/README.md
/rato/README.md
.rato/
.cache_indexador/
.continue/
.embeddings/

# Banco de dados
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*-shm
*-wal

# Documentos acadêmicos (PRIVADO)
*.md
!rato/scripts/README.md

# Scripts pessoais
*.sh
*.py
!digerir.py
!rato/scripts/digerir.py
!rato/scripts/escavar.py
!rato/scripts/farejar.py
!rato/scripts/limpar.py
!rato/scripts/roer.py
!rato/scripts/rato.sh
!rato/scripts/rato_toca.py

# Pastas com dados
fichas/
relacoes/
leituras-brutas/
textos\ limpos/
PDF/

# Python
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/
venv/
.venv

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
